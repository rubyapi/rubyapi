KAMAL_REGISTRY_PASSWORD=$(aws ecr get-login-password --profile rubyapi --region us-east-1)

SECRETS=$(kamal secrets fetch --adapter aws_secrets_manager --account rubyapi rubyapi/production)

RAILS_MASTER_KEY=$(kamal secrets extract RAILS_MASTER_KEY $SECRETS)
DATABASE_URL=$(kamal secrets extract DATABASE_URL $SECRETS)
CACHE_DATABASE_URL=$(kamal secrets extract CACHE_DATABASE_URL $SECRETS)
QUEUE_DATABASE_URL=$(kamal secrets extract QUEUE_DATABASE_URL $SECRETS)
